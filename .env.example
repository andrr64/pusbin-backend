DB_URL=jdbc:postgresql://localhost:5432/pusbin
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_ACCESS_TOKEN_EXPIRY_MS=900000
JWT_REFRESH_TOKEN_EXPIRY_MS=259200000

CORS_ALLOWED_ORIGINS=http://localhost:3000

SERVER_PORT=8080

# IAM rate limiting (optional — defaults shown)
# IAM_LOGIN_MAX_ATTEMPTS=5
# IAM_LOGIN_WINDOW_SECONDS=60
# IAM_REGISTER_MAX_ATTEMPTS=3
# IAM_REGISTER_WINDOW_SECONDS=60

# IAM account lockout (optional — defaults shown)
# Locks a single account (NIP) after repeated failed logins, regardless of IP —
# protects against distributed/automated credential-stuffing attacks.
# IAM_ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
# IAM_ACCOUNT_LOCKOUT_WINDOW_SECONDS=300
# IAM_ACCOUNT_LOCKOUT_SECONDS=900
# IAM_RATE_LIMIT_CLEANUP_INTERVAL_MS=300000
